// Prisma Schema for TaskPulse
// Discord Webhook Task Scheduler

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Task status enum
enum TaskStatus {
  active
  paused
}

/// Task execution log status enum
enum LogStatus {
  success
  failed
}

/// Scheduled task that sends Discord webhook messages
model Task {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  schedule    String     // Cron expression (e.g., "*/5 * * * *")
  webhookUrl  String     @map("webhook_url")
  payloadJson Json       @map("payload_json") @db.JsonB
  maxRetry    Int        @default(3) @map("max_retry")
  status      TaskStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  logs TaskLog[]

  @@map("tasks")
}

/// Execution log for a scheduled task
model TaskLog {
  id            String    @id @default(uuid()) @db.Uuid
  taskId        String    @map("task_id") @db.Uuid
  executionTime DateTime  @map("execution_time")
  status        LogStatus
  retryCount    Int       @default(0) @map("retry_count")
  message       String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_logs")
}
